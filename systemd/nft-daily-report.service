[Unit]
Description=NFT Firewall Daily Status Report — sends Good Morning report to Keybase
After=network-online.target

[Service]
Type=oneshot
User=fw-admin
UMask=0077
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectHostname=true
ProtectKernelLogs=true
ProtectKernelModules=true
LockPersonality=true
RestrictRealtime=true
SystemCallArchitectures=native
WorkingDirectory=/opt/nft-firewall
ExecStart=/usr/bin/python3 /opt/nft-firewall/src/main.py firewall-report --weekly --image --image-theme dark
ExecStartPost=/usr/bin/python3 /opt/nft-firewall/src/main.py maintenance
Environment=PYTHONPATH=/opt/nft-firewall/src
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nft-daily-report
